  <decision name="Loan Approval" id="_E161C8B7-B261-4496-B7B3-068823B6261E">
    <variable id="_10488F05-EAF7-4C44-9BDD-BDDB28D6EDA4" name="Loan Approval" typeRef="boolean" />
    <informationRequirement id="_FC59905B-5394-4586-9C6D-DB447686E23B">
      <requiredDecision href="#_C9F1AEAF-8954-4C32-9F79-224793A2F8E3" />
    </informationRequirement>
    <informationRequirement id="_039B01EE-59D6-4C07-A4E1-05FF204F9639">
      <requiredDecision href="#_AD0A78AF-9AF0-4939-9E7F-64F4650D310A" />
    </informationRequirement>
    <knowledgeRequirement id="_855A14F0-8D9A-4B63-898C-0D5A8542E05A">
      <requiredKnowledge href="#_66811A4A-FEA6-40B9-BF3E-83215D7DEBA0" />
    </knowledgeRequirement>
    <literalExpression id="_A812BF6F-6205-4976-9A81-E6388E987FFA" typeRef="boolean" label="Loan Approval">
      <text>Risk Category != &quot;HIGH&quot;
and Financial Eligibility = true</text>
    </literalExpression>
  </decision>
  <decision name="Risk Category" id="_AD0A78AF-9AF0-4939-9E7F-64F4650D310A">
    <variable name="Risk Category" id="_BC82EDB3-EF84-4731-AE1F-94DC43FD1C46" typeRef="string" />
    <informationRequirement id="_6CFF652E-5A8B-473C-81B6-005960D507BB">
      <requiredInput href="#_2609F265-7C21-47DF-9FF9-9554B660EC0B" />
    </informationRequirement>
    <knowledgeRequirement id="_51491275-5EF1-48A7-B15B-E4EB6443524D">
      <requiredKnowledge href="#_7A2E92DD-95D6-458D-BEE3-102A8A5DAF00" />
    </knowledgeRequirement>
    <literalExpression id="_B6B469CA-3475-406F-B417-363FF8FC3187" typeRef="string" label="Risk Category">
      <text>if Calculate Risk Score() = 3 then &quot;LOW&quot;
else if Calculate Risk Score() = 2 then &quot;MEDIUM&quot;
else &quot;HIGH&quot;</text>
    </literalExpression>
  </decision>
  <decision name="Financial Eligibility" id="_C9F1AEAF-8954-4C32-9F79-224793A2F8E3">
    <variable name="Financial Eligibility" id="_C8137E07-BB88-49F1-8533-3FDCFEF842CA" typeRef="boolean" />
    <informationRequirement id="_A7D33DD9-1FF1-4DF8-9003-456B68283C39">
      <requiredInput href="#_2609F265-7C21-47DF-9FF9-9554B660EC0B" />
    </informationRequirement>
    <knowledgeRequirement id="_FDB23A77-203C-43D6-A3A4-4AE122AC7639">
      <requiredKnowledge href="#_D798587D-ADDF-4968-97F0-D7D2682D6734" />
    </knowledgeRequirement>
    <literalExpression id="_EB073A84-08B4-4723-90A4-9B4E8BCFE75E" typeRef="boolean" label="Financial Eligibility">
      <text>Calculate Financial Strength() &gt; 30000</text>
    </literalExpression>
  </decision>
  <businessKnowledgeModel name="Calculate Risk Score" id="_7A2E92DD-95D6-458D-BEE3-102A8A5DAF00">
    <variable name="Calculate Risk Score" id="_1BA83FD0-BFE0-4C92-B2C9-3F1E8780CFE2" typeRef="number" />
    <encapsulatedLogic label="Calculate Risk Score" typeRef="number" id="_5E14A13D-1995-49C3-A1AA-EEE9D7871B05" kind="FEEL">
      <formalParameter id="_4D4F3D07-46F0-44C4-B8B9-6E69F0444C31" name="LoanApplication" typeRef="LoanApplication" />
      <literalExpression id="_AF9D09F7-7990-4828-8CF5-50AD13272A76" typeRef="LoanApplication" label="Return">
        <text>if LoanApplication.customer.creditScore &gt;= 750 then 3
else if LoanApplication.customer.creditScore &gt;= 650 then 2
else 1</text>
      </literalExpression>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="Calculate Financial Strength" id="_D798587D-ADDF-4968-97F0-D7D2682D6734">
    <variable name="Calculate Financial Strength" id="_F48E65C9-26A2-466A-BCF2-3BB81FB18FB1" typeRef="number" />
    <encapsulatedLogic label="Calculate Financial Strength" typeRef="number" id="_089E5C61-C9DD-4D95-BEBA-5FE765B8D6B7" kind="FEEL">
      <formalParameter id="_3CDB824C-F141-4FFD-A293-34D21E70F1F2" name="LoanApplication" typeRef="LoanApplication" />
      <literalExpression id="_D3D81370-2C8C-433F-8CCC-36121C5B3498" label="Return">
        <text>LoanApplication.financials.monthlyIncome 
+ sum(LoanApplication.financials.otherIncomes) 
- LoanApplication.financials.existingEMIs</text>
      </literalExpression>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <inputData name="LoanApplication" id="_2609F265-7C21-47DF-9FF9-9554B660EC0B">
    <variable name="LoanApplication" id="_5AC06892-2ECA-40EB-B448-31BC46C896CF" typeRef="LoanApplication" />
  </inputData>
