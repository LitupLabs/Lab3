  <decision name="EMI Calculation" id="_4111A8A5-0D91-43DB-884D-9D6C92318D73">
    <variable id="_B55FDD03-9298-4AAD-B49B-5DB01C34CEC5" typeRef="string" name="EMI Calculation" />
    <informationRequirement id="_0844CA5E-C3C2-44D0-9DEF-AB1EBDF858CC">
      <requiredInput href="#_4E3B8B7D-62FF-4922-B5A9-C376BC85515D" />
    </informationRequirement>
    <informationRequirement id="_FE8059A0-CA91-49A2-95BF-883D37E88C8A">
      <requiredDecision href="#_BDE01F6C-0F72-4242-A3DC-AB6154415022" />
    </informationRequirement>
    <literalExpression id="_44B817B1-EDD6-4E33-8926-A1F481EAF6D7" typeRef="string" label="EMI Calculation">
      <text>Risk_Category[
  LoanApplication.applicant.creditScore &gt;= minScore and LoanApplication.applicant.creditScore &lt;= maxScore
].RiskCategory[1]</text>
    </literalExpression>
  </decision>
