  <decision name="NumOfLiveTrades" id="_44CDB231-842A-4A51-8C2F-9CECF02B9A98">
    <variable id="_96C9AAA5-7433-42EC-B7A8-3D233E880172" typeRef="number" name="NumOfLiveTrades" />
    <informationRequirement id="_DD11ECFC-1844-4C38-93CF-46D48C24B00D">
      <requiredInput href="#_FF2E3AF0-E84B-422F-B18A-120E72CD096E" />
    </informationRequirement>
    <literalExpression id="_23A70CA6-DE88-4488-9D02-FA7F43155BC3" typeRef="number" label="NumOfLiveTrades">
      <text>count(
  LoanRequest.applicant.tbl_tradelines[
    tl_closed_date = date and time(&quot;1900-01-01T00:00:00&quot;)
    or tl_closed_date = null
    or tl_closed_date = &quot;&quot;
    or tl_closed_date = &quot;null&quot;
  ]
)</text>
    </literalExpression>
  </decision>
  <decision name="UnSecuredLoans" id="_62D01B7C-92A2-4779-9A55-D8B2C39874FF">
    <variable name="UnSecuredLoans" id="_28C58F07-47C8-4CC1-9236-7D1431246CBF" typeRef="number" />
    <informationRequirement id="_61AF3A0D-F83B-4731-9443-D9D14A37B9C0">
      <requiredInput href="#_FF2E3AF0-E84B-422F-B18A-120E72CD096E" />
    </informationRequirement>
    <informationRequirement id="_77FC75AC-0AAE-42B8-B4F5-1E6429B10813">
      <requiredDecision href="#_E2DF38FD-F760-4FAC-B6EE-9D199AA09792" />
    </informationRequirement>
    <literalExpression id="_478A91DB-EEFA-4B4F-89BC-8E635DADE592" typeRef="number" label="UnSecuredLoans">
      <text>
count(
  LoanRequest.applicant.tbl_tradelines[

tl_acct_type in [
  &quot;BUSINESSLOAN&quot;,
  &quot;CONSUMERLOAN&quot;,
  &quot;EDUCATIONLOAN&quot;,
  &quot;LOANONCREDITCARD&quot;,
  &quot;MICROFINANCEHOUSINGLOAN&quot;,
  &quot;PERSONALLOAN&quot;,
  &quot;MUDRALOANSSHISHUKISHORTARUN&quot;,
  &quot;OTHER&quot;,
  &quot;PRIMEMINISTERJAANDHANYOJANAOVERDRAFT&quot;
] 
    and
   [ tl_closed_date = date and time(&quot;1900-01-01T00:00:00&quot;)
    or tl_closed_date = null
    or tl_closed_date = &quot;&quot;
    or tl_closed_date = &quot;null&quot; ]
  ]
)
</text>
    </literalExpression>
  </decision>
  <decision name="UnsecTradesList" id="_E2DF38FD-F760-4FAC-B6EE-9D199AA09792">
    <variable name="UnsecTradesList" id="_A3ABF9C5-7000-4EB9-BEC9-F52949187DE1" typeRef="Unsec_Trades" />
    <informationRequirement id="_DB03DC34-6728-4339-882C-66E3A25706D9">
      <requiredInput href="#_FF2E3AF0-E84B-422F-B18A-120E72CD096E" />
    </informationRequirement>
    <literalExpression id="_A761CCF2-9434-42F7-A9A7-60DD7CD78CA0" typeRef="Unsec_Trades" label="UnsecTradesList">
      <text>[
  &quot;BUSINESSLOAN&quot;,
  &quot;CONSUMERLOAN&quot;,
  &quot;EDUCATIONLOAN&quot;,
  &quot;LOANONCREDITCARD&quot;,
  &quot;MICROFINANCEHOUSINGLOAN&quot;,
  &quot;PERSONALLOAN&quot;,
  &quot;MUDRALOANSSHISHUKISHORTARUN&quot;,
  &quot;OTHER&quot;,
  &quot;PRIMEMINISTERJAANDHANYOJANAOVERDRAFT&quot;
]</text>
    </literalExpression>
  </decision>
  <decision name="Values" id="_7F1C2F7D-E838-49B2-A596-BFE0042817FE">
    <variable name="Values" id="_6014B6E4-F297-4403-B4AA-CAA0F081D416" />
    <informationRequirement id="_1ECC73B6-0FC6-49C1-96D2-7671A25D4400">
      <requiredInput href="#_FF2E3AF0-E84B-422F-B18A-120E72CD096E" />
    </informationRequirement>
    <informationRequirement id="_D484AFD4-A8CA-48A0-8B16-BEC5D98C6D91">
      <requiredDecision href="#_E2DF38FD-F760-4FAC-B6EE-9D199AA09792" />
    </informationRequirement>
    <literalExpression id="_EF05F5F2-925B-4CAB-811C-562DB7A6D730" label="Values">
      <text> ([
  for t in LoanRequest.applicant.tbl_tradelines
  return replace(t.tl_acct_type, &quot; &quot;, &quot;&quot;) in UnsecTradesList
])</text>
    </literalExpression>
  </decision>
  <decision name="Final" id="_407BA7BA-5029-4C67-BD73-16024694D507">
