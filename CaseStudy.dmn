  <decision name="NumOfLiveTrades" id="_44CDB231-842A-4A51-8C2F-9CECF02B9A98">
    <variable id="_96C9AAA5-7433-42EC-B7A8-3D233E880172" typeRef="number" name="NumOfLiveTrades" />
    <informationRequirement id="_DD11ECFC-1844-4C38-93CF-46D48C24B00D">
      <requiredInput href="#_FF2E3AF0-E84B-422F-B18A-120E72CD096E" />
    </informationRequirement>
    <literalExpression id="_23A70CA6-DE88-4488-9D02-FA7F43155BC3" typeRef="number" label="NumOfLiveTrades">
      <text>count(
  LoanRequest.applicant.tbl_tradelines[
    tl_closed_date = date and time(&quot;1900-01-01T00:00:00&quot;)
    or tl_closed_date = null
    or tl_closed_date = &quot;&quot;
    or tl_closed_date = &quot;null&quot;
  ]
)</text>
    </literalExpression>
  </decision>
