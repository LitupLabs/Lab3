  <decision name="TotalIncome" id="_B6C4C518-709C-40A0-ACC3-8449CD129695">
    <variable id="_76994FD9-CCDF-4F65-BD0C-2FF0DD2C2198" typeRef="number" name="TotalIncome" />
    <informationRequirement id="_7974AC57-227D-42F4-B772-F4F62150F421">
      <requiredInput href="#_CC9D7C4B-0DCB-4BF0-87D1-539EC443643D" />
    </informationRequirement>
    <literalExpression id="_7FBF7AFE-166E-47C2-81A5-B68EAF8C126D" typeRef="number" label="TotalIncome">
      <text>LoanApplication.financials.monthlyIncome 
+ sum(LoanApplication.financials.otherIncomes)</text>
    </literalExpression>
  </decision>
  <decision name="EMI Ratio" id="_573535D2-7EF8-401E-8C0C-E3EAF82601A6">
    <variable name="EMI Ratio" id="_868E4BEE-33E5-4CEE-9A8C-D340E9D81A6B" typeRef="number" />
    <informationRequirement id="_CB78A3E4-3EF7-4091-9C98-3BED2D3A2004">
      <requiredDecision href="#_B6C4C518-709C-40A0-ACC3-8449CD129695" />
    </informationRequirement>
    <informationRequirement id="_6A901B71-FB94-4333-AC4C-E552BA7D2695">
      <requiredInput href="#_CC9D7C4B-0DCB-4BF0-87D1-539EC443643D" />
    </informationRequirement>
    <literalExpression id="_F79DF775-5AFA-4A01-A59B-582CABDBDA43" typeRef="number" label="EMI Ratio">
      <text>LoanApplication.financials.existingEMIs / TotalIncome</text>
    </literalExpression>
  </decision>
  <decision name="Eligibility" id="_C7774D4E-EB2C-47AB-BAF1-DCF1E8C8B2ED">
    <variable name="Eligibility" id="_159DBD2B-DF8B-4C21-A5E7-EF444C14FE5D" typeRef="boolean" />
    <informationRequirement id="_8B0F962A-0D47-425E-8802-6B1BB1803C58">
      <requiredDecision href="#_573535D2-7EF8-401E-8C0C-E3EAF82601A6" />
    </informationRequirement>
    <literalExpression id="_6D1650FD-DFD9-4169-9C4D-90FCBB90C722" typeRef="boolean" label="Eligibility">
      <text>EMI Ratio &lt; 0.4</text>
    </literalExpression>
  </decision>
  <decision name="High Income Flag" id="_1C347EF6-0CA9-4510-BC33-28C05D429890">
    <variable name="High Income Flag" id="_7E9141BF-B019-45CA-B152-F3CE032EF26F" typeRef="boolean" />
    <informationRequirement id="_68762334-5C4E-400C-8247-AFF2444C324D">
      <requiredDecision href="#_B6C4C518-709C-40A0-ACC3-8449CD129695" />
    </informationRequirement>
    <literalExpression id="_06679BF8-E500-469B-B5C7-D3BEC509EF24" typeRef="boolean" label="High Income Flag">
      <text>TotalIncome&gt;100000</text>
    </literalExpression>
  </decision>
  <decision name="Risk Category" id="_9BC3F428-FF7C-4C7D-A717-02F32F03D962">
    <variable name="Risk Category" id="_1F866B6B-C748-4A3A-921C-68FF40E01A1D" typeRef="RiskCategory" />
    <informationRequirement id="_CD3A3BC6-68BE-40A0-841D-7B828DCFEE1A">
      <requiredDecision href="#_573535D2-7EF8-401E-8C0C-E3EAF82601A6" />
    </informationRequirement>
    <decisionTable id="_F4C64702-809E-415E-A317-94AA5E7B313E" typeRef="RiskCategory" hitPolicy="OUTPUT ORDER" label="Risk Category">
      <input id="_E87B909B-9C00-4417-AA4E-AD9384156BDA">
        <inputExpression id="_02EC7909-B1A7-45D7-BABA-8C6A6F07C55F" typeRef="number">
          <text>EMI Ratio</text>
        </inputExpression>
      </input>
      <output id="_6827F117-E6B5-444F-BB3C-1F064DE46601" />
      <annotation name="Annotations" />
      <rule id="_FFF724FA-BC62-4335-A8E6-6B8D9780FCD0">
        <inputEntry id="_533885B9-880A-4211-B06D-29FD3E561CF2">
          <text>&lt; .3</text>
        </inputEntry>
        <outputEntry id="_D3897AB7-29D7-449D-9ED8-41BB7E22203E">
          <text>&quot;LOW&quot;</text>
        </outputEntry>
        <annotationEntry>
          <text>// Your annotations here</text>
        </annotationEntry>
      </rule>
      <rule id="_A2A4E341-07B9-4483-A198-DD6118F241C1">
        <inputEntry id="_4777CDA8-CDCB-4175-BAA1-2BCFAD23F6C6">
          <text>[.3 .. .5]</text>
        </inputEntry>
        <outputEntry id="_ECF3572E-147C-4B08-8090-BCE12D99BAA2">
          <text>&quot;MEDIUM&quot;</text>
        </outputEntry>
        <annotationEntry>
          <text></text>
        </annotationEntry>
      </rule>
      <rule id="_D52169DF-17C1-4922-8F83-6EF2911C6246">
        <inputEntry id="_328BA6EE-D743-488E-A25A-AC026506DD07">
          <text>&gt;=.4</text>
        </inputEntry>
        <outputEntry id="_3022FB68-7C61-4167-8064-48B6C9A6787B">
          <text>&quot;HIGH&quot;</text>
        </outputEntry>
        <annotationEntry>
          <text></text>
        </annotationEntry>
      </rule>
    </decisionTable>
  </decision>
