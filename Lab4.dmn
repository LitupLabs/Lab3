  <decision name="Risk Category" id="_FA79EC7F-2126-4819-A375-3C12B4D1E684">
    <variable name="Risk Category" id="_229E3F53-E2E0-4FEF-A26A-4A6D16278733" typeRef="string" />
    <informationRequirement id="_78CFA921-CD21-476C-AABC-96E1AD3CBCDF">
      <requiredInput href="#_98559022-D7B7-4E9D-88D5-72A57B296FB4" />
    </informationRequirement>
    <knowledgeRequirement id="_571BA0F1-4611-4BAB-8182-8238A922A802">
      <requiredKnowledge href="#_89CEDB34-A53C-46FD-B7BD-67EC68A69DD6" />
    </knowledgeRequirement>
    <literalExpression id="_5335282C-3D17-4AB2-A2AE-5E66991237AE" typeRef="string" label="Risk Category">
      <text>if Calculate Risk Score() = 3 then &quot;LOW&quot;
else if Calculate Risk Score() = 2 then &quot;MEDIUM&quot;
else &quot;HIGH&quot;</text>
    </literalExpression>
  </decision>
  <decision name="Financial Eligibility" id="_DDB98B72-59B2-45C1-BD3B-50931D94ADC0">
    <variable name="Financial Eligibility" id="_BDC509F7-FE6F-48C1-B1B8-ADBB8A208387" typeRef="boolean" />
    <informationRequirement id="_9159A245-C05D-4CD1-8A4D-38AF9C4C96C3">
      <requiredInput href="#_98559022-D7B7-4E9D-88D5-72A57B296FB4" />
    </informationRequirement>
    <knowledgeRequirement id="_81F18DD2-11DF-4973-847F-5D99C1FED08E">
      <requiredKnowledge href="#_CE0868EE-6A49-4CA3-A284-2B7F4F83BB35" />
    </knowledgeRequirement>
    <literalExpression id="_6990ABAF-1217-40B7-A884-7BDF743D3066" typeRef="boolean" label="Financial Eligibility">
      <text>Calculate Financial Strength() &gt; 30000</text>
    </literalExpression>
  </decision>
  <decision name="Loan Approval" id="_F445791A-A94E-45F8-90F5-5A0E57DAF6FF">
    <variable name="Loan Approval" id="_CB92D381-E69D-49E4-B5F7-B3D8045FEB9D" typeRef="boolean" />
    <informationRequirement id="_0DC46514-644E-4B50-AB97-3FEC3A6E2CE5">
      <requiredDecision href="#_DDB98B72-59B2-45C1-BD3B-50931D94ADC0" />
    </informationRequirement>
    <informationRequirement id="_A0D33AE3-9CF9-4D3E-BFC0-46B78F0D0616">
      <requiredDecision href="#_FA79EC7F-2126-4819-A375-3C12B4D1E684" />
    </informationRequirement>
    <literalExpression id="_15D5C053-CACE-4DC4-BDEB-2EBC272B2CF9" typeRef="boolean" label="Loan Approval">
      <text>Risk Category != &quot;HIGH&quot;
and Financial Eligibility = true</text>
    </literalExpression>
  </decision>
  <businessKnowledgeModel name="Calculate Risk Score" id="_89CEDB34-A53C-46FD-B7BD-67EC68A69DD6">
    <variable name="Calculate Risk Score" id="_404AEA67-3647-4738-8968-B18EC6AB834C" typeRef="number" />
    <encapsulatedLogic label="Calculate Risk Score" typeRef="number" id="_7E401C37-B0C2-4616-A05A-AC18486D54A0" kind="FEEL">
      <formalParameter id="_1684B8EF-BA30-472F-A873-C51816FCE679" name="LoanApplication" typeRef="LoanApplication" />
      <literalExpression id="_42D480A5-07D1-430A-9C83-235347F0B963" label="Return">
        <text>if LoanApplication.customer.creditScore &gt;= 750 then 3
else if LoanApplication.customer.creditScore &gt;= 650 then 2
else 1</text>
      </literalExpression>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="Calculate Financial Strength" id="_CE0868EE-6A49-4CA3-A284-2B7F4F83BB35">
    <variable name="Calculate Financial Strength" id="_BDD50E95-04BF-49E8-88A6-BCE299BD4FE5" typeRef="number" />
    <encapsulatedLogic label="Calculate Financial Strength" typeRef="number" id="_CFEAEA86-DAC2-495A-865E-22583531D662" kind="FEEL">
      <formalParameter id="_B0250541-F970-4AFA-93A9-584D9C235628" name="LoanApplication" typeRef="LoanApplication" />
      <literalExpression id="_AF40519B-216D-44E3-8192-D5E6083E7A9D" label="Return">
        <text>LoanApplication.financials.monthlyIncome 
+ sum(LoanApplication.financials.otherIncomes) 
- LoanApplication.financials.existingEMIs</text>
      </literalExpression>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <inputData name="LoanApplication" id="_98559022-D7B7-4E9D-88D5-72A57B296FB4">
    <variable name="LoanApplication" id="_A41F919A-AD0C-461F-9340-295FD920F158" typeRef="LoanApplication" />
  </inputData>
