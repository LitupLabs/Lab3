  <decision name="EMI Calculation" id="_4111A8A5-0D91-43DB-884D-9D6C92318D73">
    <variable id="_B55FDD03-9298-4AAD-B49B-5DB01C34CEC5" typeRef="number" name="EMI Calculation" />
    <informationRequirement id="_A9F8A7E8-34C4-4A8D-A704-8D987DB242C0">
      <requiredInput href="#_4E3B8B7D-62FF-4922-B5A9-C376BC85515D" />
    </informationRequirement>
    <context id="_0B7746B6-DEF4-4E59-B8DC-EE31BE5D7153" typeRef="number" label="EMI Calculation">
      <contextEntry id="_6ABB7989-D1C6-457D-A9FE-3F3A44A661A9">
        <variable id="_BE0D413E-B2F6-49AC-9DA1-9F4BFAC6FEA9" name="principal" typeRef="number" />
        <literalExpression id="_62EB2095-7056-4C56-BBEF-B9D3918AA5DF" typeRef="number" label="principal">
          <text>LoanApplication.loan.amount</text>
        </literalExpression>
      </contextEntry>
      <contextEntry id="_BB084BE1-CC3A-4F6D-BA96-9988E55FA3B6">
        <variable id="_D37E1265-0152-4078-A6E9-6D58E5D7417B" name="rate" typeRef="number">
          <description></description>
        </variable>
        <literalExpression id="_FD746F95-48F9-4321-913C-4C0DD3902331" typeRef="number" label="rate">
          <text>LoanApplication.loan.interestRate / 12</text>
        </literalExpression>
      </contextEntry>
      <contextEntry id="_7A4BC71F-A2D4-4456-8C43-0D6378CAB11F">
        <variable id="_F55946E1-78EA-4396-8EE9-9ABC84088BD6" name="tenure" typeRef="number">
          <description></description>
        </variable>
        <literalExpression id="_C8B2CE8D-0E0A-40DF-8703-8A119906A816" typeRef="number" label="tenure">
          <text>LoanApplication.loan.tenure</text>
        </literalExpression>
      </contextEntry>
      <contextEntry id="_56E60EBD-EEAF-48BB-8BB7-9BB5430AD914">
        <variable id="_DBFB290F-4C88-4908-997B-C1753BF046E6" name="emi" typeRef="number">
          <description></description>
        </variable>
        <literalExpression id="_4B91E201-709B-480C-9C18-2EBCCD733BDD" typeRef="number" label="emi">
          <text>(principal * rate) /
  (1 - (1 + rate) ** (-tenure))</text>
        </literalExpression>
      </contextEntry>
      <contextEntry id="_4E6F16AC-5F65-4EA9-82EA-2EB05413F379">
        <literalExpression id="_E564F0E8-9958-4AA0-9641-9D5FF37F263A" label="EMI Calculation">
          <text>emi</text>
        </literalExpression>
      </contextEntry>
    </context>
  </decision>
